generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String
}
model Patient {
  id         Int        @id @default(autoincrement())
  name       String
  age        Int
  gender     String
  analyses   Analysis[]
  createdAt  DateTime   @default(now())
}

model Analysis {
  id           Int      @id @default(autoincrement())
  patientId    Int
  patient      Patient  @relation(fields: [patientId], references: [id])
  imageUrl     String
  analysisType String
  riskLevel    String
  status       String
  createdAt    DateTime @default(now())
}